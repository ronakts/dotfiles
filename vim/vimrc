" Personal vimrc.
" Plugin manager: vim-plug (https://github.com/junegunn/vim-plug).
" install.sh ensures vim-plug is bootstrapped, then runs :PlugInstall.

set nocompatible

filetype plugin indent on
syntax enable

" ---- core editor behavior ----
set encoding=utf-8
set fileencoding=utf-8
set hidden                    " keep buffers around when switching
set history=1000
set undolevels=1000
set updatetime=300
set ttimeoutlen=10            " quicker reaction to <Esc>
set ttyfast                   " assume fast terminal — smoother redraw
set lazyredraw                " skip redraw during macros — faster
set backspace=indent,eol,start
set autoread                  " pick up external changes to open files
set showcmd                   " show partial command in the last line
set showmatch                 " briefly highlight matching bracket on insert

set mouse=a                   " mouse in all modes
set clipboard=unnamed         " yank/paste through system clipboard

" splits open in the natural reading direction
set splitright
set splitbelow

" tab completion menu (the *good* one)
set wildmenu
set wildmode=longest:full,full
set wildignorecase

" no swap / backup noise
set nobackup
set nowritebackup
set noswapfile

" persistent undo across vim sessions
if has('persistent_undo')
    let s:undodir = expand('~/.vim/undo')
    if !isdirectory(s:undodir)
        call mkdir(s:undodir, 'p', 0700)
    endif
    let &undodir = s:undodir
    set undofile
endif

" true color in terminal (paired with tmux true-color override)
if has('termguicolors')
    set termguicolors
endif

" line numbering
set number
set relativenumber

" status / scroll
set laststatus=2
set scrolloff=5
set sidescrolloff=8
set signcolumn=auto

" search
set incsearch
set hlsearch
set ignorecase
set smartcase

" ---- leader ----
let mapleader=","

" handy mappings
nnoremap <silent> <leader><space> :nohlsearch<CR>
nnoremap <leader>w :w<CR>
nnoremap <leader>q :q<CR>

" yank to end of line — consistent with D and C (Y default is yy, almost
" never what you want)
nnoremap Y y$

" navigate by display lines, not file lines (huge with wrapped text)
nnoremap j gj
nnoremap k gk

" disable Ex mode (it's a footgun, nobody types :visual to escape it)
nnoremap Q <Nop>

" restore cursor to last position when reopening a file
augroup VimrcRestoreCursor
    autocmd!
    autocmd BufReadPost *
        \ if line("'\"") > 1 && line("'\"") <= line("$") |
        \     execute "normal! g`\"" |
        \ endif
augroup END

" ---- plugins (vim-plug) ----
call plug#begin('~/.vim/plugged')

" Look & feel
Plug 'morhetz/gruvbox'
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'

" Navigation & search
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'

" Git
Plug 'tpope/vim-fugitive'
Plug 'airblade/vim-gitgutter'

" Editing
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-surround'
Plug 'jiangmiao/auto-pairs'

" Linting / fixing (works without an LSP setup; uses project tools like
" ruff, eslint, shellcheck if installed).
Plug 'dense-analysis/ale'

call plug#end()

" ---- color scheme ----
" silent! so the first run (before :PlugInstall) doesn't error out.
silent! colorscheme gruvbox
set background=dark

" ---- airline / tabline ----
let g:airline_theme = 'gruvbox'
let g:airline_powerline_fonts = 0
let g:airline#extensions#tabline#enabled = 1
let g:airline#extensions#tabline#left_sep = ' '
let g:airline#extensions#tabline#left_alt_sep = '|'

" ---- fzf ----
nnoremap <leader>f :Files<CR>
nnoremap <leader>b :Buffers<CR>
nnoremap <leader>g :Rg<CR>
nnoremap <leader>h :History<CR>

" ---- gitgutter ----
" Don't lag the editor: only refresh on save / focus / file changes.
let g:gitgutter_eager = 0

" ---- ALE ----
" Lint on save only — feels like a normal editor, no flicker on every keystroke.
let g:ale_lint_on_text_changed = 'never'
let g:ale_lint_on_insert_leave = 0
let g:ale_lint_on_enter = 1
let g:ale_fix_on_save = 0    " set to 1 once you're comfortable with auto-fixers
" Sensible default fixers per language; unused entries are harmless.
let g:ale_fixers = {
\   '*':          ['remove_trailing_lines', 'trim_whitespace'],
\   'python':     ['ruff', 'ruff_format'],
\   'javascript': ['prettier', 'eslint'],
\   'typescript': ['prettier', 'eslint'],
\}
